# OpenAI API key (required for LLM classification)
OPENAI_API_KEY=sk-your-key-here

# Optional: override the default classifier model
# CLASSIFIER_MODEL=gpt-4o-mini

# Redis connection (defaults shown)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# --- Production (frontend + API) ---
# URL the browser uses to reach the backend (required in production)
# NEXT_PUBLIC_API_URL=https://api.yourdomain.com

# Comma-separated origins allowed by CORS (backend)
# CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
